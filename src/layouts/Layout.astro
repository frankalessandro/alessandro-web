---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alessandro | Developer',
  description = 'Portfolio de Alessandro — desarrollador web.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Always start at the top on load/reload -->
    <script is:inline>history.scrollRestoration = 'manual'; window.scrollTo(0, 0);</script>
    <!-- Init theme & lang before paint — prevents flash of wrong theme/lang -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme') || 'dark';
        const l = localStorage.getItem('lang') || 'es';
        document.documentElement.dataset.theme = t;
        document.documentElement.dataset.lang = l;
        // Mark that JS is running so we can pre-hide GSAP-animated elements
        // before paint (prevents a flash of content before the intro plays).
        document.documentElement.classList.add('js-anim');
      })();
    </script>
    <!-- Fonts: preconnect first, then load the CSS non-blocking via print→all trick -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <!-- Intro loader: the brand mark assembles, then the screen splits open.
         Shown only when JS is on (html.js-anim) so no-JS users never get a
         stuck overlay; GSAP removes it once the intro plays. -->
    <div id="intro-loader" aria-hidden="true">
      <div class="intro-panel intro-panel-l"></div>
      <div class="intro-panel intro-panel-r"></div>
      <Logo class="intro-logo" />
    </div>

    <!-- Global starfield -->
    <canvas
      id="starfield"
      class="fixed inset-0 w-full h-full pointer-events-none z-0"
    ></canvas>

    <!-- Scroll progress bar -->
    <div
      id="scroll-progress"
      class="fixed top-0 left-0 h-0.5 bg-accent z-9999 transition-[width] duration-80 ease-linear shadow-[0_0_8px_rgba(110,231,183,0.6)] w-0"
    ></div>

    <slot />

    <!-- Back to top button -->
    <button
      id="back-to-top"
      aria-label="Volver arriba"
      class="fixed bottom-6 right-6 z-50 w-9 h-9 flex items-center justify-center rounded-lg border border-border bg-bg-2/80 backdrop-blur-sm text-muted hover:text-accent hover:border-accent/40 transition-all duration-200 opacity-0 pointer-events-none"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <script>
      // GSAP animations (hero intro, scroll reveals, parallax, tilt)
      import '../scripts/animations.ts';
    </script>

    <script>
      // Back to top
      const btt = document.getElementById('back-to-top');
      function updateBtt() {
        if (!btt) return;
        if (window.scrollY > 300) {
          btt.style.opacity = '1';
          btt.style.pointerEvents = 'auto';
        } else {
          btt.style.opacity = '0';
          btt.style.pointerEvents = 'none';
        }
      }
      btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      window.addEventListener('scroll', updateBtt, { passive: true });
    </script>

    <script>
      // Scroll progress bar
      const bar = document.getElementById('scroll-progress');
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        if (bar) bar.style.width = pct + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });

      // Global starfield
      const canvasEl = document.getElementById('starfield');
      const ctx2d = canvasEl instanceof HTMLCanvasElement ? canvasEl.getContext('2d') : null;
      if (canvasEl instanceof HTMLCanvasElement && ctx2d) {
        // Non-null typed aliases so narrowing survives inside nested functions.
        const canvas: HTMLCanvasElement = canvasEl;
        const ctx: CanvasRenderingContext2D = ctx2d;
        {
          type Tone = 'white' | 'gray' | 'accent';
          interface Star {
            x: number; y: number; r: number; depth: number;
            baseAlpha: number; twinkleSpeed: number; phase: number; tone: Tone;
            // slow glow burst
            glowNext: number; glowStart: number; glowDur: number;
            // magnetism: spring displacement + velocity around the resting position
            vx: number; vy: number; dx: number; dy: number;
          }
          let stars: Star[] = [];
          let width = 0, height = 0;
          let dpr = Math.min(window.devicePixelRatio || 1, 2);
          let px = 0, py = 0, cx = 0, cy = 0;
          // Actual cursor position in CSS px (for constellation lines + magnetism);
          // parked off-screen until the first move so nothing connects on load.
          let mx = -9999, my = -9999;
          // "Antigravity" hover boost: toggled by [data-particle-hover] enter/leave,
          // smoothed each frame. Idle = gentle attraction; boosted = repulsion + brighter links.
          let hoverTarget = 0, hoverCur = 0;
          // Scroll-warp: streak length tracks scroll speed, direction tracks scroll sign.
          let lastScrollY = window.scrollY;
          let warp = 0, warpDir = 1;

          const rand = (min: number, max: number) => Math.random() * (max - min) + min;

          function pickTone(): Tone {
            const n = Math.random();
            if (n < 0.35) return 'accent'; // verdes
            if (n < 0.6) return 'gray';     // grises
            return 'white';                  // blancas
          }

          function buildStars() {
            const count = Math.min(280, Math.floor((width * height) / 5500));
            stars = Array.from({ length: count }, () => ({
              x: Math.random() * width,
              y: Math.random() * height,
              r: rand(0.5, 1.8),
              depth: rand(0.2, 1),
              baseAlpha: rand(0.35, 0.95),
              twinkleSpeed: rand(0.15, 0.45),
              phase: rand(0, Math.PI * 2),
              tone: pickTone(),
              // glow: first burst after a short random delay, then repeats on its own cadence
              glowNext: rand(0.5, 7),
              glowStart: -999,
              glowDur: 0,
              vx: 0, vy: 0, dx: 0, dy: 0,
            }));
          }

          let lastW = 0, lastH = 0;

          function applySize() {
            width = window.innerWidth;
            height = window.innerHeight;
            dpr = Math.min(window.devicePixelRatio || 1, 2);
            canvas.width = Math.round(width * dpr);
            canvas.height = Math.round(height * dpr);
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          }

          function rebuild() {
            applySize();
            lastW = window.innerWidth;
            lastH = window.innerHeight;
            buildStars();
          }

          // Mobile browsers fire `resize` when the URL bar shows/hides while
          // scrolling — that only changes the height by a small amount. Rebuilding
          // the field on every such event makes the stars flicker and teleport, so
          // ignore those: only react to a width change (orientation/resize) or a
          // large height change. Coalesce bursts of events into one rAF tick.
          let resizeRaf = 0;
          function onResize() {
            if (resizeRaf) return;
            resizeRaf = requestAnimationFrame(() => {
              resizeRaf = 0;
              const w = window.innerWidth, h = window.innerHeight;
              if (w === lastW && Math.abs(h - lastH) < 120) return;
              rebuild();
            });
          }

          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          // Touch devices: skip the always-on glow blur (canvas shadowBlur is the
          // single heaviest per-frame cost on mobile GPUs).
          const lowPower = window.matchMedia('(pointer: coarse)').matches;
          // Constellation + magnetism are desktop-only: they need a real cursor and
          // the per-frame spring/line work isn't worth it on phones.
          const enableField = !reduceMotion && !lowPower;

          let rafId = 0;
          const start = performance.now();
          function draw(now: number) {
            const t = (now - start) / 1000;
            ctx.clearRect(0, 0, width, height);
            cx += (px - cx) * 0.05;
            cy += (py - cy) * 0.05;

            // Smooth the hover boost and read scroll velocity for the warp streaks.
            hoverCur += (hoverTarget - hoverCur) * 0.08;
            const sy = window.scrollY;
            const rawVel = sy - lastScrollY;
            lastScrollY = sy;
            if (Math.abs(rawVel) > 0.5) warpDir = rawVel > 0 ? 1 : -1;
            warp += (Math.min(Math.abs(rawVel), 60) - warp) * 0.12;

            // Constellation/magnetism field: radius grows on hover, force flips from
            // gentle attraction (idle) to repulsion (hover = "antigravity").
            const fieldR = enableField ? 120 + hoverCur * 90 : 0;
            const fieldR2 = fieldR * fieldR;
            const forceSign = -1 + hoverCur * 2;
            const near: { x: number; y: number; a: number }[] = [];

            for (const s of stars) {
              // slow, gentle twinkle
              const twinkle = reduceMotion ? 1 : 0.8 + 0.2 * Math.sin(t * s.twinkleSpeed + s.phase);

              // glow burst: schedule next glow, compute a slow, smooth boost
              let glowBoost = 0;
              if (!reduceMotion) {
                if (t >= s.glowNext) {
                  s.glowStart = t;
                  // slow rise and fall: 2.5–5s per glow
                  s.glowDur = rand(2.5, 5);
                  // next glow between 3 and 11 seconds later (each star on its own cadence)
                  s.glowNext = t + rand(3, 11);
                }
                const elapsed = t - s.glowStart;
                if (elapsed >= 0 && elapsed < s.glowDur) {
                  // smooth bell curve using sine: gentle rise and fall
                  const p = elapsed / s.glowDur;
                  glowBoost = Math.sin(p * Math.PI);
                }
              }

              const alpha = Math.min(1, s.baseAlpha * twinkle + glowBoost * (1 - s.baseAlpha));
              // mouse parallax
              const ox = cx * s.depth * 40;
              const oy = cy * s.depth * 40;

              // Magnetism: each star springs back to its resting position; when the
              // cursor is within range it's pulled toward (idle) or pushed away (hover).
              if (enableField) {
                s.vx += -s.dx * 0.012;
                s.vy += -s.dy * 0.012;
                s.vx *= 0.86;
                s.vy *= 0.86;
                const cdx = (s.x + ox) - mx;
                const cdy = (s.y + oy) - my;
                const cd2 = cdx * cdx + cdy * cdy;
                if (cd2 < fieldR2 && cd2 > 0.01) {
                  const cd = Math.sqrt(cd2);
                  const f = (1 - cd / fieldR) * (0.5 + hoverCur * 1.6) * forceSign;
                  s.vx += (cdx / cd) * f;
                  s.vy += (cdy / cd) * f;
                }
                s.dx += s.vx;
                s.dy += s.vy;
              }

              const rx = s.x + ox + s.dx;
              const ry = s.y + oy + s.dy;
              // glow briefly expands the star radius too
              const rad = (s.r * (0.6 + s.depth * 0.6)) * (1 + glowBoost * 0.5);

              // Collect stars within cursor range so we can wire them up afterwards.
              if (enableField && mx > -9000) {
                const ldx = rx - mx, ldy = ry - my;
                const ld2 = ldx * ldx + ldy * ldy;
                if (ld2 < fieldR2) near.push({ x: rx, y: ry, a: 1 - Math.sqrt(ld2) / fieldR });
              }

              const glowColor =
                s.tone === 'accent' ? 'rgba(110,231,183,0.9)'
                : s.tone === 'gray' ? 'rgba(160,160,170,0.8)'
                : 'rgba(240,240,240,0.8)';
              ctx.shadowBlur = glowBoost > 0.05
                ? 8 + glowBoost * 16
                : (!lowPower && s.depth > 0.6 ? 6 : 0);
              ctx.shadowColor = glowColor;

              const fill =
                s.tone === 'accent' ? `rgba(110,231,183,${alpha})`
                : s.tone === 'gray' ? `rgba(160,160,170,${alpha})`
                : `rgba(240,240,240,${alpha})`;

              // While scrolling fast, draw the star as a streak; otherwise a dot.
              if (warp > 1) {
                const len = Math.min(warp * s.depth * 0.9, 34);
                ctx.strokeStyle = fill;
                ctx.lineWidth = rad * 1.4;
                ctx.lineCap = 'round';
                ctx.beginPath();
                ctx.moveTo(rx, ry);
                ctx.lineTo(rx, ry + warpDir * len);
                ctx.stroke();
              } else {
                ctx.beginPath();
                ctx.arc(rx, ry, rad, 0, Math.PI * 2);
                ctx.fillStyle = fill;
                ctx.fill();
              }
            }

            // Constellation lines: link near-cursor stars to each other and to the
            // cursor. Pairwise is cheap because `near` only holds in-range stars.
            if (near.length > 1) {
              ctx.shadowBlur = 0;
              const linkR2 = fieldR2 * 0.55;
              for (let i = 0; i < near.length; i++) {
                const a = near[i];
                const toCursor = a.a * (0.18 + hoverCur * 0.45);
                if (toCursor > 0.02) {
                  ctx.strokeStyle = `rgba(110,231,183,${toCursor})`;
                  ctx.lineWidth = 0.6 + hoverCur * 0.5;
                  ctx.beginPath();
                  ctx.moveTo(a.x, a.y);
                  ctx.lineTo(mx, my);
                  ctx.stroke();
                }
                for (let j = i + 1; j < near.length; j++) {
                  const b = near[j];
                  const dx = a.x - b.x, dy = a.y - b.y;
                  const dd = dx * dx + dy * dy;
                  if (dd < linkR2) {
                    const la = (1 - Math.sqrt(dd) / (fieldR * 0.74)) * Math.min(a.a, b.a) * (0.32 + hoverCur * 0.6);
                    if (la > 0.02) {
                      ctx.strokeStyle = `rgba(110,231,183,${la})`;
                      ctx.lineWidth = 0.6 + hoverCur * 0.5;
                      ctx.beginPath();
                      ctx.moveTo(a.x, a.y);
                      ctx.lineTo(b.x, b.y);
                      ctx.stroke();
                    }
                  }
                }
              }
            }

            ctx.shadowBlur = 0;
            rafId = requestAnimationFrame(draw);
          }

          window.addEventListener('resize', onResize, { passive: true });
          window.addEventListener('orientationchange', onResize, { passive: true });
          if (!reduceMotion) {
            window.addEventListener('mousemove', (e) => {
              px = (e.clientX / window.innerWidth - 0.5) * 2;
              py = (e.clientY / window.innerHeight - 0.5) * 2;
              mx = e.clientX;
              my = e.clientY;
            }, { passive: true });
            // Cursor left the window — drop the constellation so no lines linger.
            window.addEventListener('mouseout', (e) => {
              if (!e.relatedTarget) { mx = -9999; my = -9999; }
            }, { passive: true });
            // "Antigravity" hover: tagged elements (project cards, hero avatar) make
            // the particles behind them light up and push away from the cursor.
            document.querySelectorAll('[data-particle-hover]').forEach((el) => {
              el.addEventListener('mouseenter', () => { hoverTarget = 1; });
              el.addEventListener('mouseleave', () => { hoverTarget = 0; });
            });
          }

          // Pause the loop while the tab is hidden — saves battery and CPU.
          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              cancelAnimationFrame(rafId);
              rafId = 0;
            } else if (!rafId) {
              rafId = requestAnimationFrame(draw);
            }
          });

          rebuild();

          // The intro overlay covers the canvas, so don't burn CPU/GPU drawing
          // stars behind it — that contention is what makes the intro feel
          // laggy. Start the loop only once the intro signals it's done (with a
          // safety fallback in case the signal never arrives).
          const startLoop = () => { if (!rafId) rafId = requestAnimationFrame(draw); };
          if (document.documentElement.classList.contains('js-anim')) {
            let started = false;
            const go = () => { if (started) return; started = true; startLoop(); };
            window.addEventListener('intro:done', go, { once: true });
            window.setTimeout(go, 4200);
          } else {
            startLoop();
          }
        }
      }
    </script>

    <script>
      // ── i18n + theme toggle ──────────────────────────────────────────────

      interface Tr { es: string; en: string; }
      type Lang = 'es' | 'en';

      const T: Record<string, Tr> = {
        'nav.home':       { es: 'Inicio',      en: 'Home' },
        'nav.about':      { es: 'Sobre mí',    en: 'About' },
        'nav.experience': { es: 'Experiencia', en: 'Experience' },
        'nav.projects':   { es: 'Proyectos',   en: 'Projects' },
        'nav.contact':    { es: 'Contacto',    en: 'Contact' },

        'hero.available':    { es: 'Disponible para trabajar', en: 'Available for work' },
        'hero.desc':         { es: 'Desarrollador Full Stack con más de 3 años de experiencia construyendo aplicaciones web escalables. Especializado en React, Node.js y APIs REST.', en: 'Full Stack Developer with 3+ years of experience building scalable web applications. Specialized in React, Node.js and REST APIs.' },
        'hero.cta.projects': { es: 'Ver proyectos', en: 'View projects' },
        'hero.cta.contact':  { es: 'Contacto',      en: 'Contact' },

        'about.label': { es: 'Sobre mí',                    en: 'About me' },
        'about.title': { es: 'Un poco de<br />mi historia', en: 'A bit about<br />my story' },

        'contact.label': { es: 'Contacto', en: 'Contact' },
        'contact.title': { es: 'Hablemos', en: "Let's talk" },
        'contact.desc':  { es: 'Si tenés un proyecto en mente, una pregunta o simplemente querés conectar — mandame un mensaje.', en: "If you have a project in mind, a question, or just want to connect — send me a message." },

        'exp.label': { es: 'Experiencia',         en: 'Experience' },
        'exp.title': { es: 'Dónde he trabajado',  en: "Where I've worked" },
      };

      const SUN  = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;
      const MOON = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;

      function applyLang(lang: Lang) {
        document.documentElement.dataset.lang = lang;
        localStorage.setItem('lang', lang);
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const entry = T[el.dataset.i18n!];
          if (entry) el.textContent = entry[lang];
        });
        document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach((el) => {
          const entry = T[el.dataset.i18nHtml!];
          if (entry) el.innerHTML = entry[lang];
        });
        const btn = document.getElementById('lang-toggle');
        if (btn) btn.textContent = lang === 'es' ? 'EN' : 'ES';
      }

      function applyTheme(theme: string) {
        document.documentElement.dataset.theme = theme;
        localStorage.setItem('theme', theme);
        const btn = document.getElementById('theme-toggle');
        if (btn) btn.innerHTML = theme === 'dark' ? SUN : MOON;
      }

      document.addEventListener('DOMContentLoaded', () => {
        const lang  = (localStorage.getItem('lang')  || 'es') as Lang;
        const theme =  localStorage.getItem('theme') || 'dark';
        applyLang(lang);
        applyTheme(theme);

        document.getElementById('lang-toggle')?.addEventListener('click', () => {
          applyLang(document.documentElement.dataset.lang === 'es' ? 'en' : 'es');
        });
        document.getElementById('theme-toggle')?.addEventListener('click', () => {
          applyTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
        });
      });
    </script>
  </body>
</html>
