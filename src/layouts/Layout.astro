---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alessandro | Developer',
  description = 'Portfolio de Alessandro — desarrollador web.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Init theme & lang before paint — prevents flash of wrong theme/lang -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme') || 'dark';
        const l = localStorage.getItem('lang') || 'es';
        document.documentElement.dataset.theme = t;
        document.documentElement.dataset.lang = l;
      })();
    </script>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Global starfield -->
    <canvas
      id="starfield"
      class="fixed inset-0 w-full h-full pointer-events-none z-0"
    ></canvas>

    <!-- Scroll progress bar -->
    <div
      id="scroll-progress"
      class="fixed top-0 left-0 h-0.5 bg-accent z-9999 transition-[width] duration-80 ease-linear shadow-[0_0_8px_rgba(110,231,183,0.6)] w-0"
    ></div>

    <slot />

    <script>
      // Scroll progress bar
      const bar = document.getElementById('scroll-progress');
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        if (bar) bar.style.width = pct + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });

      // Global starfield
      const canvas = document.getElementById('starfield');
      if (canvas instanceof HTMLCanvasElement) {
        const ctx = canvas.getContext('2d');
        if (ctx) {
          type Tone = 'white' | 'gray' | 'accent';
          interface Star {
            x: number; y: number; r: number; depth: number;
            baseAlpha: number; twinkleSpeed: number; phase: number; tone: Tone;
            // slow glow burst
            glowNext: number; glowStart: number; glowDur: number;
          }
          let stars: Star[] = [];
          let width = 0, height = 0;
          let dpr = Math.min(window.devicePixelRatio || 1, 2);
          let px = 0, py = 0, cx = 0, cy = 0;

          const rand = (min: number, max: number) => Math.random() * (max - min) + min;

          function pickTone(): Tone {
            const n = Math.random();
            if (n < 0.35) return 'accent'; // verdes
            if (n < 0.6) return 'gray';     // grises
            return 'white';                  // blancas
          }

          function buildStars() {
            const count = Math.min(280, Math.floor((width * height) / 5500));
            stars = Array.from({ length: count }, () => ({
              x: Math.random() * width,
              y: Math.random() * height,
              r: rand(0.5, 1.8),
              depth: rand(0.2, 1),
              baseAlpha: rand(0.35, 0.95),
              twinkleSpeed: rand(0.15, 0.45),
              phase: rand(0, Math.PI * 2),
              tone: pickTone(),
              // glow: first burst after a short random delay, then repeats on its own cadence
              glowNext: rand(0.5, 7),
              glowStart: -999,
              glowDur: 0,
            }));
          }

          let lastW = 0, lastH = 0;

          function applySize() {
            width = window.innerWidth;
            height = window.innerHeight;
            dpr = Math.min(window.devicePixelRatio || 1, 2);
            canvas.width = Math.round(width * dpr);
            canvas.height = Math.round(height * dpr);
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          }

          function rebuild() {
            applySize();
            lastW = window.innerWidth;
            lastH = window.innerHeight;
            buildStars();
          }

          // Mobile browsers fire `resize` when the URL bar shows/hides while
          // scrolling — that only changes the height by a small amount. Rebuilding
          // the field on every such event makes the stars flicker and teleport, so
          // ignore those: only react to a width change (orientation/resize) or a
          // large height change. Coalesce bursts of events into one rAF tick.
          let resizeRaf = 0;
          function onResize() {
            if (resizeRaf) return;
            resizeRaf = requestAnimationFrame(() => {
              resizeRaf = 0;
              const w = window.innerWidth, h = window.innerHeight;
              if (w === lastW && Math.abs(h - lastH) < 120) return;
              rebuild();
            });
          }

          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          // Touch devices: skip the always-on glow blur (canvas shadowBlur is the
          // single heaviest per-frame cost on mobile GPUs).
          const lowPower = window.matchMedia('(pointer: coarse)').matches;

          let rafId = 0;
          const start = performance.now();
          function draw(now: number) {
            const t = (now - start) / 1000;
            ctx.clearRect(0, 0, width, height);
            cx += (px - cx) * 0.05;
            cy += (py - cy) * 0.05;

            for (const s of stars) {
              // slow, gentle twinkle
              const twinkle = reduceMotion ? 1 : 0.8 + 0.2 * Math.sin(t * s.twinkleSpeed + s.phase);

              // glow burst: schedule next glow, compute a slow, smooth boost
              let glowBoost = 0;
              if (!reduceMotion) {
                if (t >= s.glowNext) {
                  s.glowStart = t;
                  // slow rise and fall: 2.5–5s per glow
                  s.glowDur = rand(2.5, 5);
                  // next glow between 3 and 11 seconds later (each star on its own cadence)
                  s.glowNext = t + rand(3, 11);
                }
                const elapsed = t - s.glowStart;
                if (elapsed >= 0 && elapsed < s.glowDur) {
                  // smooth bell curve using sine: gentle rise and fall
                  const p = elapsed / s.glowDur;
                  glowBoost = Math.sin(p * Math.PI);
                }
              }

              const alpha = Math.min(1, s.baseAlpha * twinkle + glowBoost * (1 - s.baseAlpha));
              // mouse parallax only — no self-drift
              const ox = cx * s.depth * 40;
              const oy = cy * s.depth * 40;
              // glow briefly expands the star radius too
              const radius = (s.r * (0.6 + s.depth * 0.6)) * (1 + glowBoost * 0.5);

              const glowColor =
                s.tone === 'accent' ? 'rgba(110,231,183,0.9)'
                : s.tone === 'gray' ? 'rgba(160,160,170,0.8)'
                : 'rgba(240,240,240,0.8)';
              ctx.shadowBlur = glowBoost > 0.05
                ? 8 + glowBoost * 16
                : (!lowPower && s.depth > 0.6 ? 6 : 0);
              ctx.shadowColor = glowColor;

              ctx.beginPath();
              ctx.arc(s.x + ox, s.y + oy, radius, 0, Math.PI * 2);
              ctx.fillStyle =
                s.tone === 'accent' ? `rgba(110,231,183,${alpha})`
                : s.tone === 'gray' ? `rgba(160,160,170,${alpha})`
                : `rgba(240,240,240,${alpha})`;
              ctx.fill();
            }
            ctx.shadowBlur = 0;
            rafId = requestAnimationFrame(draw);
          }

          window.addEventListener('resize', onResize, { passive: true });
          window.addEventListener('orientationchange', onResize, { passive: true });
          if (!reduceMotion) {
            window.addEventListener('mousemove', (e) => {
              px = (e.clientX / window.innerWidth - 0.5) * 2;
              py = (e.clientY / window.innerHeight - 0.5) * 2;
            }, { passive: true });
          }

          // Pause the loop while the tab is hidden — saves battery and CPU.
          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              cancelAnimationFrame(rafId);
              rafId = 0;
            } else if (!rafId) {
              rafId = requestAnimationFrame(draw);
            }
          });

          rebuild();
          rafId = requestAnimationFrame(draw);
        }
      }
    </script>

    <script>
      // ── i18n + theme toggle ──────────────────────────────────────────────

      interface Tr { es: string; en: string; }
      type Lang = 'es' | 'en';

      const T: Record<string, Tr> = {
        'nav.home':       { es: 'Inicio',      en: 'Home' },
        'nav.about':      { es: 'Sobre mí',    en: 'About' },
        'nav.experience': { es: 'Experiencia', en: 'Experience' },
        'nav.projects':   { es: 'Proyectos',   en: 'Projects' },
        'nav.contact':    { es: 'Contacto',    en: 'Contact' },

        'hero.available':    { es: 'Disponible para trabajar', en: 'Available for work' },
        'hero.desc':         { es: 'Desarrollador Full Stack con más de 3 años de experiencia construyendo aplicaciones web escalables. Especializado en React, Node.js y APIs REST.', en: 'Full Stack Developer with 3+ years of experience building scalable web applications. Specialized in React, Node.js and REST APIs.' },
        'hero.cta.projects': { es: 'Ver proyectos', en: 'View projects' },
        'hero.cta.contact':  { es: 'Contacto',      en: 'Contact' },

        'about.label': { es: 'Sobre mí',                    en: 'About me' },
        'about.title': { es: 'Un poco de<br />mi historia', en: 'A bit about<br />my story' },

        'contact.label': { es: 'Contacto', en: 'Contact' },
        'contact.title': { es: 'Hablemos', en: "Let's talk" },
        'contact.desc':  { es: 'Si tenés un proyecto en mente, una pregunta o simplemente querés conectar — mandame un mensaje.', en: "If you have a project in mind, a question, or just want to connect — send me a message." },

        'exp.label': { es: 'Experiencia',         en: 'Experience' },
        'exp.title': { es: 'Dónde he trabajado',  en: "Where I've worked" },
      };

      const SUN  = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;
      const MOON = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;

      function applyLang(lang: Lang) {
        document.documentElement.dataset.lang = lang;
        localStorage.setItem('lang', lang);
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const entry = T[el.dataset.i18n!];
          if (entry) el.textContent = entry[lang];
        });
        document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach((el) => {
          const entry = T[el.dataset.i18nHtml!];
          if (entry) el.innerHTML = entry[lang];
        });
        const btn = document.getElementById('lang-toggle');
        if (btn) btn.textContent = lang === 'es' ? 'EN' : 'ES';
      }

      function applyTheme(theme: string) {
        document.documentElement.dataset.theme = theme;
        localStorage.setItem('theme', theme);
        const btn = document.getElementById('theme-toggle');
        if (btn) btn.innerHTML = theme === 'dark' ? SUN : MOON;
      }

      document.addEventListener('DOMContentLoaded', () => {
        const lang  = (localStorage.getItem('lang')  || 'es') as Lang;
        const theme =  localStorage.getItem('theme') || 'dark';
        applyLang(lang);
        applyTheme(theme);

        document.getElementById('lang-toggle')?.addEventListener('click', () => {
          applyLang(document.documentElement.dataset.lang === 'es' ? 'en' : 'es');
        });
        document.getElementById('theme-toggle')?.addEventListener('click', () => {
          applyTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
        });
      });
    </script>
  </body>
</html>
