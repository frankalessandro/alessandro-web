---
const roles = ["Full Stack Developer", "Frontend Developer", "React & Node.js"];
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden"
>
  <div
    class="relative z-10 max-w-5xl mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center pt-20"
  >
    <!-- Left: text -->
    <div>
      <p data-i18n="hero.available" data-anim-hero="badge" class="text-accent text-xs font-mono mb-4 tracking-widest uppercase">
        Disponible para trabajar
      </p>

      <!-- Typewriter -->
      <div data-anim-hero="type" class="mb-2 h-10 flex items-center">
        <span class="font-mono text-muted text-sm">
          <span class="text-accent">&gt;</span>{" "}
        </span>
        <span id="typewriter" class="font-mono text-sm text-text ml-1"></span>
        <span
          class="inline-block w-0.5 h-[1em] bg-accent ml-0.5 align-middle animate-[blink_1s_step-end_infinite]"
        ></span>
      </div>

      <h1
        id="hero-name"
        data-anim-hero="name"
        class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-text leading-tight mb-4"
      >
        Frank
        <span class="text-accent">Roldan</span>
      </h1>

      <p data-i18n="hero.desc" data-anim-hero="desc" class="text-muted text-sm max-w-md leading-relaxed mb-8">
        Desarrollador Full Stack con más de 3 años de experiencia construyendo
        aplicaciones web escalables. Especializado en React, Node.js y APIs
        REST.
      </p>

      <!-- Social links -->
      <div data-anim-hero="desc" class="flex items-center gap-3">
        <a
          href="https://github.com/frankalessandro"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>

        <a
          href="https://www.linkedin.com/in/frank-alessandro/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <a
          href="#contact"
          aria-label="Enviar correo"
          class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <polyline points="2,4 12,13 22,4"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Right: avatar placeholder (hidden until photo is ready) -->
    <div class="hidden"></div>
  </div>
</section>


<script define:vars={{ roles }}>
  const el = document.getElementById("typewriter");
  let roleIdx = 0;
  let charIdx = 0;
  let deleting = false;

  function tick() {
    const role = roles[roleIdx];
    if (!deleting) {
      el.textContent = role.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === role.length) {
        deleting = true;
        setTimeout(tick, 2000);
        return;
      }
    } else {
      el.textContent = role.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        deleting = false;
        roleIdx = (roleIdx + 1) % roles.length;
      }
    }
    setTimeout(tick, deleting ? 40 : 80);
  }

  tick();
</script>
