const panels = (job: (typeof jobs)[number]) => [
  { icon: '⚠', labelEs: 'Problema', labelEn: 'Problem',   color: 'text-amber-400', dot: 'bg-amber-400', glow: 'rgba(251,191,36,0.5)',   contentEs: job.problem,  contentEn: job.problemEn,  list: false },
  { icon: '◈', labelEs: 'Solución', labelEn: 'Solution',  color: 'text-accent',    dot: 'bg-accent',    glow: 'rgba(110,231,183,0.5)',  contentEs: job.solution, contentEn: job.solutionEn, list: false },
  { icon: '↗', labelEs: 'Resultados', labelEn: 'Results', color: 'text-sky-400',   dot: 'bg-sky-400',   glow: 'rgba(56,189,248,0.5)',   contentEs: job.results,  contentEn: job.resultsEn,  list: true  },
];
---

<section id="experience" class="px-4 sm:px-6 py-28 md:py-40 max-w-5xl mx-auto">
  <p data-i18n="exp.label" data-anim-head class="text-accent font-mono text-xs tracking-widest uppercase mb-3">Experiencia</p>
  <h2 data-i18n="exp.title" data-exp-title class="text-3xl font-black text-text mb-12 tracking-tight">Dónde he trabajado</h2>

  <div class="flex flex-col items-center gap-12 md:gap-16">
    {jobs.map((job, ji) => (
      <div
        class="exp-reveal w-full md:w-[62%] rounded-2xl"
        data-exp-card
        data-side={ji % 2 === 0 ? 'left' : 'right'}
        data-index={ji}
      >
      <!-- scan line that sweeps across the card during reveal -->
      <div class="exp-scan-line" aria-hidden="true"></div>

      <article
        class="exp-card group relative w-full rounded-2xl border border-border bg-bg-2 overflow-hidden"
      >
        <!-- accent line that grows on hover -->
        <span class="pointer-events-none absolute left-0 top-0 h-full w-px bg-linear-to-b from-transparent via-accent/60 to-transparent scale-y-0 group-hover:scale-y-100 origin-center transition-transform duration-500 ease-out"></span>

        <!-- Header -->
        <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-border" data-exp-header>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-text font-semibold text-base tracking-tight" data-exp-company>{job.company}</h3>
              <p class="text-muted text-xs font-mono mt-1" data-exp-role>
                <span data-lang="es">{job.role}</span>
                <span data-lang="en">{job.roleEn}</span>
                {' · '}{job.period}
              </p>
            </div>
            <span data-exp-num class="shrink-0 text-[10px] font-mono text-muted/60 border border-border rounded-md px-2 py-1 group-hover:border-accent/30 group-hover:text-accent/70 transition-colors duration-500">
              0{ji + 1}
            </span>
          </div>
        </div>

        <!-- Accordions -->
        <div class="divide-y divide-border/70">
          {panels(job).map((item) => (
            <div class="acc">
              <button
                type="button"
                class="acc-trigger w-full flex items-center justify-between px-4 sm:px-6 py-4 cursor-pointer select-none text-left transition-colors duration-300 hover:bg-white/2.5"
                aria-expanded="false"
              >
                <span class="flex items-center gap-3 text-sm font-medium">
                  <span
                    class={`acc-icon font-mono text-base leading-none ${item.color} transition-transform duration-300`}
                    style={`text-shadow: 0 0 12px ${item.glow};`}
                  >
                    {item.icon}
                  </span>
                  <span class={item.color}>
                    <span data-lang="es">{item.labelEs}</span>
                    <span data-lang="en">{item.labelEn}</span>
                  </span>
                </span>
                <span class={`acc-chevron flex items-center justify-center w-6 h-6 rounded-full border border-border ${item.color} text-[10px] transition-all duration-300`}>
                  <span class="block transition-transform duration-300">∨</span>
                </span>
              </button>

              <!-- grid-rows trick for smooth height -->
              <div class="acc-panel grid grid-rows-[0fr] transition-[grid-template-rows] duration-450 ease-in-out">
                <div class="overflow-hidden">
                  <div class="px-4 sm:px-6 pb-5 pt-1">
                    {item.list ? (
                      <>
                        <ul class="space-y-2.5" data-lang="es">
                          {(item.contentEs as string[]).map((r) => (
                            <li class="flex gap-2.5 text-muted text-sm leading-relaxed">
                              <span class={`${item.color} font-mono mt-0.5 shrink-0`}>→</span>
                              <span>{r}</span>
                            </li>
                          ))}
                        </ul>
                        <ul class="space-y-2.5" data-lang="en">
                          {(item.contentEn as string[]).map((r) => (
                            <li class="flex gap-2.5 text-muted text-sm leading-relaxed">
                              <span class={`${item.color} font-mono mt-0.5 shrink-0`}>→</span>
                              <span>{r}</span>
                            </li>
                          ))}
                        </ul>
                      </>
                    ) : (
                      <>
                        <p class="text-muted text-sm leading-relaxed" data-lang="es">{item.contentEs as string}</p>
                        <p class="text-muted text-sm leading-relaxed" data-lang="en">{item.contentEn as string}</p>
                      </>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </article>
      </div>
    ))}
  </div>
</section>

<style>
  /* Wrapper clips the scan-line so it never pushes past the card bounds */
  .exp-reveal { position: relative; overflow: hidden; border-radius: 1rem; }

  /* The scan line that sweeps across the card during reveal.
     left: 0 is the baseline; GSAP moves it with `x` transform. */
  .exp-scan-line {
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(110, 231, 183, 0.9) 40%,
      rgba(110, 231, 183, 1) 50%,
      rgba(110, 231, 183, 0.9) 60%,
      transparent 100%
    );
    box-shadow: 0 0 18px 6px rgba(110, 231, 183, 0.55),
                0 0 40px 12px rgba(110, 231, 183, 0.2);
    pointer-events: none;
    z-index: 10;
    /* GSAP controls position and opacity */
    opacity: 0;
  }

  .exp-card {
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.5s ease,
      box-shadow 0.5s ease;
  }

  .exp-card:hover {
    transform: translateY(-5px);
    border-color: rgba(110, 231, 183, 0.3);
    box-shadow: 0 14px 50px -14px rgba(110, 231, 183, 0.22);
  }

  .acc.open .acc-panel  { grid-template-rows: 1fr; }
  .acc.open .acc-chevron > span { transform: rotate(180deg); }
  .acc.open .acc-chevron { background-color: rgba(255, 255, 255, 0.03); }
  .acc.open .acc-icon { transform: scale(1.15); }

  @media (prefers-reduced-motion: reduce) {
    .acc-panel { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('#experience .acc').forEach((acc) => {
    const trigger = acc.querySelector<HTMLButtonElement>('.acc-trigger');
    trigger?.addEventListener('click', () => {
      const isOpen = acc.classList.toggle('open');
      trigger.setAttribute('aria-expanded', String(isOpen));
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) continue;
        entry.target.querySelectorAll<HTMLElement>('.acc.open').forEach((acc) => {
          acc.classList.remove('open');
          acc.querySelector<HTMLButtonElement>('.acc-trigger')?.setAttribute('aria-expanded', 'false');
        });
      }
    },
    { threshold: 0 }
  );

  document.querySelectorAll<HTMLElement>('#experience .exp-card').forEach((card) => {
    observer.observe(card);
  });
</script>
