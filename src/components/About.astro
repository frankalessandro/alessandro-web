---
---

<section id="about" class="px-6 py-24 max-w-5xl mx-auto">
  <div
    id="about-inner"
    class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start"
    style="opacity: 0; transform: scale(1.14); transform-origin: center top; will-change: transform, opacity;"
  >
    <div>
      <p data-i18n="about.label" class="text-accent font-mono text-xs tracking-widest uppercase mb-3">Sobre mí</p>
      <h2 data-i18n-html="about.title" class="text-3xl font-black text-text mb-6 tracking-tight">
        Un poco de<br />mi historia
      </h2>
      <div class="space-y-4 text-muted text-sm leading-relaxed">
        <p data-lang="es">
          Soy Frank Alessandro Roldan, desarrollador Full Stack de Colombia con más de 3 años de experiencia construyendo aplicaciones web escalables. Trabajo con React, Node.js, PHP y PostgreSQL, con foco en APIs REST, rendimiento e interfaces accesibles.
        </p>
        <p data-lang="en">
          I'm Frank Alessandro Roldan, a Full Stack developer from Colombia with 3+ years of experience building scalable web apps. I work with React, Node.js, PHP and PostgreSQL, focused on REST APIs, performance and accessible interfaces.
        </p>
        <p data-lang="es">
          He colaborado con equipos ágiles en proyectos reales que impactan cientos de usuarios, desde sistemas administrativos de gestión hasta plataformas de votación electrónica. Me apasiona el código limpio y el aprendizaje continuo.
        </p>
        <p data-lang="en">
          I've collaborated with agile teams on real projects impacting hundreds of users, from administrative management systems to electronic voting platforms. I'm passionate about clean code and continuous learning.
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <p class="text-accent font-mono text-xs tracking-widest uppercase">Skills</p>

      {[
        { label: 'Frontend', items: ['React', 'Astro', 'JavaScript ES6+', 'TypeScript', 'Tailwind CSS', 'Redux', 'Vite'] },
        { label: 'Backend', items: ['Node.js', 'Express.js', 'PHP (Yii2)', 'PostgreSQL', 'RESTful APIs', 'JWT'] },
        { label: 'DevOps & Tools', items: ['Docker', 'Git / GitHub', 'CI/CD', 'Jest', 'Linux CLI', 'Jira'] },
      ].map(({ label, items }) => (
        <div>
          <p class="text-text text-xs font-medium mb-2">{label}</p>
          <div class="flex flex-wrap gap-2">
            {items.map((i) => (
              <span class="text-xs px-3 py-1 rounded border border-border text-muted font-mono hover:border-accent/40 hover:text-accent transition-colors">
                {i}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('about-inner');
  if (el) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      el.style.opacity = '1';
      el.style.transform = 'none';
    } else {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            el.style.transition = 'transform 0.85s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.7s ease';
            el.style.transform = 'scale(1)';
            el.style.opacity = '1';
          } else {
            el.style.transition = 'none';
            el.style.transform = 'scale(1.14)';
            el.style.opacity = '0';
          }
        },
        { threshold: 0.12 }
      );
      observer.observe(el);
    }
  }
</script>
