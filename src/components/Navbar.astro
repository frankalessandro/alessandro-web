---
import Logo from './Logo.astro';

const links = [
  { href: '#hero',       i18n: 'nav.home',       label: 'Inicio' },
  { href: '#about',      i18n: 'nav.about',      label: 'Sobre mí' },
  { href: '#experience', i18n: 'nav.experience',  label: 'Experiencia' },
  { href: '#projects',   i18n: 'nav.projects',   label: 'Proyectos' },
  { href: '#contact',    i18n: 'nav.contact',    label: 'Contacto' },
];
---

<header
  id="navbar"
  class="fixed top-2 left-0 right-0 z-50 flex justify-center px-4"
>
  <nav
    id="nav-pill"
    class="flex items-center gap-6 px-6 py-3 rounded-2xl border border-white/10 backdrop-blur-md bg-bg/75 transition-[background-color,border-color,box-shadow] duration-300"
  >
    <a
      href="#hero"
      aria-label="Inicio"
      class="text-accent mr-2 hover:text-text transition-colors duration-200"
    >
      <Logo class="w-7 h-7" />
    </a>

    <div class="hidden sm:flex items-center gap-5">
      {links.map((l) => (
        <a
          href={l.href}
          data-i18n={l.i18n}
          class="text-sm text-muted hover:text-text transition-colors duration-200 font-medium"
        >
          {l.label}
        </a>
      ))}
    </div>

    <a
      href="/cv.pdf"
      download
      class="ml-2 text-xs font-mono px-3 py-1.5 rounded-lg border border-accent/40 text-accent hover:bg-accent/10 transition-colors duration-200"
    >
      CV
    </a>

    <!-- Theme & language toggles -->
    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="w-8 h-8 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
      >
        <!-- replaced by JS on load -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <button
        id="lang-toggle"
        aria-label="Toggle language"
        class="font-mono text-xs px-2.5 py-1.5 rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
      >
        EN
      </button>
    </div>
  </nav>
</header>
