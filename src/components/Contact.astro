---
---

<section id="contact" class="px-4 sm:px-6 py-28 md:py-40 max-w-5xl mx-auto">
  <div class="max-w-lg mx-auto">
    <p data-i18n="contact.label" data-anim-head class="text-accent font-mono text-xs tracking-widest uppercase mb-3">Contacto</p>
    <h2 data-i18n="contact.title" data-anim-head class="text-3xl font-black text-text mb-4 tracking-tight">
      Hablemos
    </h2>
    <p data-i18n="contact.desc" data-anim-head class="text-muted text-sm mb-8 leading-relaxed">
      Si tenés un proyecto en mente, una pregunta o simplemente querés conectar — mandame un mensaje.
    </p>

    <!-- Social quick-links -->
    <div class="flex items-center gap-3 mb-10" data-anim-contact>
      <a
        href="https://github.com/frankalessandro"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>

      <a
        href="https://www.linkedin.com/in/frank-alessandro/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <a
        href="mailto:frank.alessandro.roldan@gmail.com"
        aria-label="Email"
        class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-accent hover:border-accent/40 transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <polyline points="2,4 12,13 22,4"/>
        </svg>
      </a>
    </div>

    <!-- Contact form -->
    <form id="contact-form" data-anim-contact class="flex flex-col gap-4">

      <!-- Reason chips -->
      <div class="flex flex-col gap-2">
        <span class="font-mono text-xs text-muted tracking-widest uppercase">¿Sobre qué querés hablar?</span>
        <div class="flex flex-wrap gap-2" role="group" aria-label="Motivo de contacto">
          {[
            { value: 'Tengo un proyecto para vos',         emoji: '🚀' },
            { value: 'Quiero que seas parte de mi equipo', emoji: '🤝' },
            { value: 'Tengo una pregunta',                 emoji: '💬' },
            { value: 'Solo quiero decir hola',             emoji: '👋' },
          ].map(({ value, emoji }, i) => (
            <label class="reason-chip cursor-pointer">
              <input
                type="radio"
                name="reason"
                value={value}
                class="sr-only"
                checked={i === 0}
              />
              <span class="inline-flex items-center gap-1.5 font-mono text-xs px-3 py-1.5 rounded-lg border border-border text-muted transition-colors duration-200 select-none">
                {emoji} {value}
              </span>
            </label>
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-name" class="font-mono text-xs text-muted tracking-widest uppercase">Nombre</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          placeholder="Tu nombre"
          class="bg-bg-2 border border-border rounded-lg px-4 py-2.5 text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/20 transition-colors duration-200"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="font-mono text-xs text-muted tracking-widest uppercase">Email</label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="tu@email.com"
          class="bg-bg-2 border border-border rounded-lg px-4 py-2.5 text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/20 transition-colors duration-200"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-message" class="font-mono text-xs text-muted tracking-widest uppercase">Mensaje</label>
        <textarea
          id="contact-message"
          name="message"
          rows="5"
          required
          placeholder="Contame en qué puedo ayudarte..."
          class="bg-bg-2 border border-border rounded-lg px-4 py-2.5 text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/20 transition-colors duration-200 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        id="contact-submit"
        class="self-start font-mono text-xs px-5 py-2.5 rounded-lg border border-accent/40 text-accent hover:bg-accent/10 transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Enviar mensaje
      </button>

      <p id="contact-status" class="font-mono text-xs hidden"></p>
    </form>
  </div>
</section>

<style>
  .reason-chip input:checked + span {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
</style>

<script>
  const W3F_KEY = 'YOUR_WEB3FORMS_KEY'; // ← reemplazá con tu key de web3forms.com

  const form    = document.getElementById('contact-form')   as HTMLFormElement   | null;
  const btn     = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const status  = document.getElementById('contact-status') as HTMLElement       | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !status) return;

    const fd      = new FormData(form);
    const name    = (fd.get('name')    as string).trim();
    const email   = (fd.get('email')   as string).trim();
    const message = (fd.get('message') as string).trim();
    const reason  = (fd.get('reason')  as string) ?? 'Contacto desde portfolio';

    const subject = `✦ ${name} te escribe — ${reason}`;

    btn.disabled     = true;
    btn.textContent  = 'Enviando...';
    status.className = 'font-mono text-xs hidden';

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: W3F_KEY,
          subject,
          name,
          email,
          message,
          from_name: name,
        }),
      });

      const json = await res.json();

      if (json.success) {
        status.textContent  = '✓ Mensaje enviado. Te respondo lo antes posible.';
        status.className    = 'font-mono text-xs text-accent';
        form.reset();
        // reset chip highlight
        (form.querySelector('input[name="reason"]') as HTMLInputElement | null)
          ?.closest('.reason-chip')
          ?.querySelector('input')
          ?.click();
      } else {
        throw new Error(json.message);
      }
    } catch {
      status.textContent = '✕ Algo salió mal. Intentá de nuevo o escribime directo a frank.alessandro.roldan@gmail.com';
      status.className   = 'font-mono text-xs text-red-400';
    } finally {
      btn.disabled    = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>
